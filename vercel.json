{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/login", "destination": "/pages/login.html" },
    { "source": "/apps", "destination": "/pages/apps.html" },
    { "source": "/settings", "destination": "/pages/settings.html" },
    { "source": "/abonnement", "destination": "/pages/abonnement.html" },
    { "source": "/", "destination": "/pages/index.html" }
  ]
}