{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login",                    "destination": "/pages/login" },
    { "source": "/dashboard",                "destination": "/pages/index" },
    { "source": "/apps/serrures",            "destination": "/apps/serrures/index" },
    { "source": "/apps/sms",                 "destination": "/apps/sms/index" },
    { "source": "/apps",                     "destination": "/pages/apps" },
