    { "source": "/abonnement",               "destination": "/pages/abonnement" },
    { "source": "/connexions",               "destination": "/pages/connexions" },
    { "source": "/apps/agent-ai",            "destination": "/apps/agent-ai/index" },
    { "source": "/apps/agent-ai/knowledge",  "destination": "/apps/agent-ai/knowledge" },
    { "source": "/apps/agent-ai/test",       "destination": "/apps/agent-ai/test" },
    { "source": "/apps/agent-ai/config",     "destination": "/apps/agent-ai/config" },
    { "source": "/apps/agent-ai/messages",   "destination": "/apps/agent-ai/messages" },
