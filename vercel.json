{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/login", "dest": "/pages/login.html" },
    { "src": "/apps", "dest": "/pages/apps.html" },
    { "src": "/settings", "dest": "/pages/settings.html" },
    { "src": "/abonnement", "dest": "/pages/abonnement.html" },
    { "src": "/(.*)", "dest": "/pages/index.html" }
  ]
}