{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/cron.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/guide",
      "destination": "/pages/guide"
    },
    {
      "source": "/m/calendrier",
      "destination": "/pages/calendrier-mobile"
    },
    {
      "source": "/login",
      "destination": "/pages/login"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/index"
    },
    {
      "source": "/apps/serrures",
      "destination": "/apps/serrures/index"
    },
    {
      "source": "/apps/sms",
      "destination": "/apps/sms/index"
    },
    {
      "source": "/apps",
      "destination": "/pages/apps"
    },
    {
      "source": "/settings",
      "destination": "/pages/settings"
    },
    {
      "source": "/abonnement",
      "destination": "/pages/abonnement"
    },
    {
      "source": "/connexions",
      "destination": "/pages/connexions"
    },
    {
      "source": "/channels-test",
      "destination": "/pages/channels-test"
    },
    {
      "source": "/biens",
      "destination": "/pages/biens"
    },
    {
      "source": "/biens/nouveau",
      "destination": "/pages/biens-nouveau"
    },
    {
      "source": "/biens/:id/calendrier",
      "destination": "/pages/biens-calendrier"
    },
    {
      "source": "/biens/:id",
      "destination": "/pages/biens-detail"
    },
    {
      "source": "/apps/agent-ai",
      "destination": "/apps/agent-ai/index"
    },
    {
      "source": "/apps/agent-ai/knowledge",
      "destination": "/apps/agent-ai/knowledge"
    },
    {
      "source": "/apps/agent-ai/test",
      "destination": "/apps/agent-ai/test"
    },
    {
      "source": "/apps/agent-ai/config",
      "destination": "/apps/agent-ai/config"
    },
    {
      "source": "/apps/agent-ai/messages",
      "destination": "/apps/agent-ai/messages"
    },
    {
      "source": "/apps/agent-ai/messagerie",
      "destination": "/apps/agent-ai/messagerie"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ]
}
